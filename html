<!DOCTYPE html><html lang="ja"><head><meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<title>上反射 タイミング計算機 - RUBY SYSTEM</title>
<style>
  :root {
    --bg-color: #0b0204;
    --panel-bg: rgba(24, 7, 10, 0.75);
    --panel-border: rgba(255, 30, 70, 0.3);
    --accent-ruby: #ff1e46;
    --accent-ruby-glow: rgba(255, 30, 70, 0.6);
    --text-primary: #ffffff;
    --text-secondary: #ffb3bf;
    --input-bg: #1f0a0e;
  }

  * {
    box-sizing: border-box;
    font-family: 'Courier New', Courier, monospace, "Helvetica Neue", Arial, sans-serif;
    -webkit-tap-highlight-color: transparent;
  }

  body {
    padding: 0;
    margin: 0;
    background-color: var(--bg-color);
    /* サイバー感を演出するメッシュ背景 */
    background-image: 
      linear-gradient(rgba(255, 30, 70, 0.03) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255, 30, 70, 0.03) 1px, transparent 1px);
    background-size: 20px 20px;
    color: var(--text-primary);
    display: flex;
    justify-content: center;
    align-items: flex-start;
    min-height: 100vh;
    padding: 15px;
  }

  .container {
    width: 100%;
    max-width: 480px;
    background: var(--panel-bg);
    border: 1px solid var(--panel-border);
    border-radius: 12px;
    padding: 20px;
    box-shadow: 0 0 25px rgba(255, 30, 70, 0.15);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
  }

  header {
    text-align: center;
    margin-bottom: 25px;
    border-bottom: 2px dashed var(--panel-border);
    padding-bottom: 12px;
  }

  h2 {
    margin: 0;
    font-size: 1.5rem;
    letter-spacing: 2px;
    color: var(--accent-ruby);
    text-shadow: 0 0 10px var(--accent-ruby-glow);
    font-weight: bold;
  }

  .system-status {
    font-size: 0.75rem;
    color: var(--text-secondary);
    margin-top: 5px;
    text-transform: uppercase;
    opacity: 0.8;
  }

  .section-title {
    font-size: 0.9rem;
    text-align: left;
    color: var(--text-secondary);
    margin: 15px 0 8px 2px;
    display: flex;
    align-items: center;
  }

  .section-title::before {
    content: "■";
    color: var(--accent-ruby);
    font-size: 0.7rem;
    margin-right: 6px;
    text-shadow: 0 0 5px var(--accent-ruby);
  }

  /* スマホの横並び3等分入力エリア */
  .grid-3 {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 10px;
  }

  /* 数値入力ボックスのカスタムデザイン */
  input[type="number"] {
    width: 100%;
    background: var(--input-bg);
    border: 1px solid var(--panel-border);
    border-radius: 6px;
    color: #fff;
    font-size: 1.2rem;
    padding: 12px 8px;
    text-align: center;
    outline: none;
    transition: all 0.2s ease;
  }

  input[type="number"]:focus {
    border-color: var(--accent-ruby);
    box-shadow: 0 0 8px rgba(255, 30, 70, 0.4);
    background: #2a0e14;
  }

  /* 突破球数 (mode) 用のカスタムセグメントコントロール（タップしやすく） */
  .mode-selector {
    display: flex;
    background: var(--input-bg);
    border: 1px solid var(--panel-border);
    border-radius: 6px;
    overflow: hidden;
  }

  .mode-btn {
    flex: 1;
    background: transparent;
    border: none;
    color: var(--text-secondary);
    font-size: 1.1rem;
    padding: 12px 0;
    cursor: pointer;
    transition: all 0.2s;
    font-weight: bold;
  }

  .mode-btn.active {
    background: var(--accent-ruby);
    color: #fff;
    text-shadow: 0 0 5px rgba(0,0,0,0.5);
    box-shadow: inset 0 0 10px rgba(0,0,0,0.2);
  }

  /* ２カラムの調整枠 */
  .grid-2 {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 10px;
  }

  /* 計算結果表示コンポーネント */
  .result-container {
    margin-top: 25px;
    background: rgba(255, 30, 70, 0.08);
    border: 1px solid var(--accent-ruby);
    border-radius: 8px;
    padding: 15px;
    text-align: center;
    position: relative;
    box-shadow: inset 0 0 15px rgba(255, 30, 70, 0.1);
  }

  .result-label {
    font-size: 0.8rem;
    color: var(--text-secondary);
    text-transform: uppercase;
    letter-spacing: 1px;
    margin-bottom: 5px;
  }

  .result {
    font-size: 3rem;
    font-weight: bold;
    color: var(--accent-ruby);
    text-shadow: 0 0 15px var(--accent-ruby-glow);
    line-height: 1;
    margin: 5px 0;
  }

  /* スマホのキーボードが出てもスクロールできるように余白を確保 */
  .footer-margin {
    height: 40px;
  }
</style>
</head>
<body>

<div class="container">
  <header>
    <h2>TIMING COMPUTING SYSTEM</h2>
    <div class="system-status">🔒 SINGLE MODE // TYPE-RUBY</div>
  </header>

  <div class="section-title">表面：落とした秒数 / 突破秒数 (最大3つ)</div>
  <div class="grid-3">
    <input type="number" id="input1" inputmode="decimal" step="0.01" oninput="calculate()" placeholder="0.00">
    <input type="number" id="input2" inputmode="decimal" step="0.01" oninput="calculate()" placeholder="0.00">
    <input type="number" id="input3" inputmode="decimal" step="0.01" oninput="calculate()" placeholder="0.00">
  </div>

  <div class="section-title">突破球数</div>
  <div class="mode-selector">
    <button class="mode-btn" id="btn-mode1" onclick="setMode(1)">1球</button>
    <button class="mode-btn active" id="btn-mode2" onclick="setMode(2)">2球</button>
    <button class="mode-btn" id="btn-mode3" onclick="setMode(3)">3球</button>
  </div>
  <!-- 内部計算用の隠しinput -->
  <input type="hidden" id="mode" value="2">

  <div class="grid-2">
    <div>
      <div class="section-title">裏面：狙う球数</div>
      <input type="number" id="n" inputmode="numeric" step="1" min="1" value="1" oninput="calculate()">
    </div>
    <div>
      <div class="section-title">裏面：ロス秒数</div>
      <input type="number" id="w" inputmode="decimal" step="0.01" value="0.00" oninput="calculate()" placeholder="0.00">
    </div>
  </div>

  <div class="result-container">
    <div class="result-label">TARGET TIMING</div>
    <div class="result" id="output">0.00 秒</div>
  </div>

  <div class="footer-margin"></div>
</div>

<script>
  // 突破球数（Mode）の切り替え用スクリプト
  function setMode(val) {
    document.getElementById('mode').value = val;
    
    // ボタンのアクティブ状態の見た目を切り替え
    document.getElementById('btn-mode1').classList.remove('active');
    document.getElementById('btn-mode2').classList.remove('active');
    document.getElementById('btn-mode3').classList.remove('active');
    
    document.getElementById('btn-mode' + val).classList.add('active');
    
    // 計算をトリガー
    calculate();
  }

  // オリジナルのロジックを完全維持
  function calculate() {
    const num1 = parseFloat(document.getElementById('input1').value) || 0;
    const num2 = parseFloat(document.getElementById('input2').value) || 0;
    const num3 = parseFloat(document.getElementById('input3').value) || 0;
    const mode = parseInt(document.getElementById('mode').value) || 2;
    const n = parseInt(document.getElementById('n').value) || 1;
    const w = parseFloat(document.getElementById('w').value) || 0;

    const S = num1 + num2 + num3;

    let t_base;
    if (mode === 1) {
      t_base = 2.5;
    } else if (mode === 2) {
      t_base = 4;
    } else if (mode === 3) {
      t_base = 5.5;
    } else {
      t_base = 4;
    }

    let t = (t_base - S) % 10;
    if (t < 0) t += 10;

    let t2 = t + 1.5 * (n - 1) - w;
    t2 = ((t2 % 10) + 10) % 10;

    const t2_display = t2.toFixed(2);
    document.getElementById('output').innerHTML = t2_display + " 秒";
  }

  // 初期起動時に一度計算を実行
  calculate();
</script>
</body></html>
